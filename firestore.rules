rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ==========================================
    // GLOBAL SAFETY NET
    // ==========================================
    match /test/connection {
      allow read: if true;
    }

    match /{document=**} {
      allow read, write: if false;
    }

    // ==========================================
    // GLOBAL HELPERS
    // ==========================================
    function isSuperAdmin() {
      return request.auth != null && (
        request.auth.uid == 'D0wKH0KjXehG2WQXzSLvwbZIVn53' ||
        request.auth.uid == 'nvwM2TPUcRfM3XbmsjzDLXJbMMp2' ||
        request.auth.uid == 'Ov2UpLIRcoZ3Z1VRMFS6rxrYcL52' ||
        ('email' in request.auth.token && (
          request.auth.token.email == 'adminrajpura@nvgroup.co.in' ||
          request.auth.token.email == 'ykaman250@gmail.com' ||
          request.auth.token.email == 'amammehra121@gmail.com' ||
          request.auth.token.email == 'nvrajpura@nvgroup.co.in'
        ))
      );
    }

    function isSignedIn() {
      return request.auth != null;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }

    function getUserData() {
      return exists(/databases/$(database)/documents/users/$(request.auth.uid))
        ? get(/databases/$(database)/documents/users/$(request.auth.uid)).data
        : null;
    }

    function getUserRole(targetOrgId) {
      let userData = getUserData();
      return isSuperAdmin() 
        ? 'superadmin' 
        : ('role' in request.auth.token 
            ? request.auth.token.role 
            : (userData != null 
                ? userData.get('orgRoles', {}).get(targetOrgId, 'viewer')
                : 'viewer'
              )
          );
    }

    function isOrgMember(targetOrgId) {
      let userData = getUserData();
      return isSignedIn() && (isSuperAdmin() || (userData != null && targetOrgId in userData.get('orgRoles', {})));
    }

    function isOrgAdmin(targetOrgId) {
      let userData = getUserData();
      return isSignedIn() && (isSuperAdmin() || (userData != null && userData.get('orgRoles', {}).get(targetOrgId, 'viewer') in ['owner', 'admin']));
    }

    function isOwner(userId) {
      return isSignedIn() && (isSuperAdmin() || request.auth.uid == userId);
    }

    // Tenant Isolation
    function isSameOrg(orgId) {
      return isSuperAdmin() || isOrgMember(orgId);
    }

    function belongsToUserOrg() {
      return isSuperAdmin() || isOrgMember(resource.data.get('orgId', null));
    }

    function creatingForUserOrg() {
      return isSuperAdmin() || isOrgMember(request.resource.data.get('orgId', null));
    }

    // ==========================================
    // VALIDATION BLUEPRINTS
    // ==========================================
    
    function isValidAsset(data) {
      return data.keys().hasAll(['name', 'category', 'status', 'orgId']) &&
             data.name is string && data.name.size() <= 200 &&
             data.category is string && data.category.size() <= 100 &&
             data.status is string && data.status.size() <= 50 &&
             (isSuperAdmin() || isOrgMember(data.orgId)) &&
             (data.get('customData', null) == null || data.customData is map);
    }

    function isValidUser(data) {
      return data.keys().hasAll(['email', 'name', 'orgRoles', 'status', 'activeOrgId']) &&
             data.email is string && data.email.size() <= 200 &&
             data.name is string && data.name.size() <= 200 &&
             data.orgRoles is map;
    }

    function isValidConfigItem(data) {
      return (data.get('name', null) == null || (data.name is string && data.name.size() > 0)) &&
             (data.get('orgId', null) == null || isSameOrg(data.orgId)) &&
             (data.get('types', null) == null || data.types is list) &&
             (data.get('assetTypes', null) == null || data.assetTypes is list) &&
             (data.get('address', null) == null || data.address is string) &&
             (data.get('city', null) == null || data.city is string) &&
             (data.get('district', null) == null || data.district is string) &&
             (data.get('state', null) == null || data.state is string) &&
             (data.get('country', null) == null || data.country is string) &&
             (data.get('pinCode', null) == null || data.pinCode is string) &&
             (data.get('departments', null) == null || data.departments is list) &&
             (data.get('vendorCode', null) == null || data.vendorCode is string) &&
             (data.get('phoneNumber', null) == null || data.phoneNumber is string) &&
             (data.get('emailAddress', null) == null || data.emailAddress is string) &&
             (data.get('bankName', null) == null || data.bankName is string) &&
             (data.get('accountName', null) == null || data.accountName is string) &&
             (data.get('accountNumber', null) == null || data.accountNumber is string) &&
             (data.get('ifscCode', null) == null || data.ifscCode is string) &&
             (data.get('contactInfo', null) == null || data.contactInfo is string) &&
             (data.get('usage', null) == null || data.usage is string) &&
             (data.get('createdAt', null) == null || data.createdAt is string || data.createdAt is timestamp);
    }

    // ==========================================
    // COLLECTION RULES
    // ==========================================

    match /organizations/{orgId} {
      allow read: if isSignedIn() && (getUserRole(orgId) == 'superadmin' || isOrgMember(orgId));
      allow create: if isSignedIn(); // For signup
      allow update: if isOrgMember(orgId) && (getUserRole(orgId) == 'owner' || getUserRole(orgId) == 'superadmin') &&
                    incoming().diff(existing()).affectedKeys().hasOnly(['name', 'currency', 'updatedAt']);
    }

    match /users/{userId} {
      // Identity isolation
      allow get: if isOwner(userId) || isOrgAdmin(existing().get('activeOrgId', null));
      allow list: if isSignedIn();
      
      allow create: if isSignedIn(); // Handled by server or signup
      allow update: if isSuperAdmin() || (isOwner(userId) && (
        incoming().diff(existing()).affectedKeys().hasOnly(['preferences', 'name', 'updatedAt', 'activeOrgId'])
      ));
      allow delete: if isSuperAdmin() && userId != request.auth.uid;
    }

    match /assets/{assetId} {
      allow get: if isSuperAdmin() || isSameOrg(resource.data.get('orgId', null));
      allow list: if isSignedIn();
      
      allow create: if isOrgAdmin(incoming().get('orgId', null)) && creatingForUserOrg() && isValidAsset(incoming());
      allow update: if isSameOrg(existing().get('orgId', null)) && isValidAsset(incoming()) && (
        isOrgAdmin(existing().get('orgId', null)) || 
        incoming().diff(existing()).affectedKeys().hasOnly(['status', 'assignedTo', 'remarks', 'updatedAt'])
      );
      allow delete: if isOrgAdmin(existing().get('orgId', null));
    }

    match /asset_categories/{id} {
        allow read: if isSuperAdmin() || isSameOrg(resource.data.get('orgId', null));
        allow create: if isOrgAdmin(incoming().get('orgId', null)) && creatingForUserOrg() && incoming().get('name', null) != null && isValidConfigItem(incoming());
        allow update: if isOrgAdmin(existing().get('orgId', null)) && belongsToUserOrg() && isValidConfigItem(incoming());
        allow delete: if isOrgAdmin(existing().get('orgId', null));
    }

    match /locations/{id} {
        allow read: if isSuperAdmin() || isSameOrg(resource.data.get('orgId', null));
        allow create: if isOrgAdmin(incoming().get('orgId', null)) && creatingForUserOrg() && incoming().get('name', null) != null && isValidConfigItem(incoming());
        allow update: if isOrgAdmin(existing().get('orgId', null)) && belongsToUserOrg() && isValidConfigItem(incoming());
        allow delete: if isOrgAdmin(existing().get('orgId', null));
    }

    match /vendors/{id} {
        allow read: if isSuperAdmin() || isSameOrg(resource.data.get('orgId', null));
        allow create: if isOrgAdmin(incoming().get('orgId', null)) && creatingForUserOrg() && incoming().get('name', null) != null && isValidConfigItem(incoming());
        allow update: if isOrgAdmin(existing().get('orgId', null)) && belongsToUserOrg() && isValidConfigItem(incoming());
        allow delete: if isOrgAdmin(existing().get('orgId', null));
    }

    match /audit_logs/{id} {
      allow read: if isSuperAdmin() || isOrgAdmin(resource.data.get('orgId', null));
      allow create: if isSuperAdmin() || (
        isSameOrg(incoming().get('orgId', null)) &&
        incoming().get('action', '') in ['CREATE', 'UPDATE', 'DELETE']
      );
      allow update, delete: if false; // Logs are immutable
    }

    match /employees/{id} {
      allow read: if isSuperAdmin() || isSameOrg(resource.data.get('orgId', null));
      allow write: if isOrgAdmin(request.method == 'delete' ? existing().get('orgId', null) : incoming().get('orgId', null));
    }

    match /asset_history/{id} {
      allow read: if isSuperAdmin() || isSameOrg(resource.data.get('orgId', null));
      allow create: if creatingForUserOrg();
      allow update, delete: if false;
    }

    match /maintenance_logs/{id} {
      allow read: if isSuperAdmin() || isSameOrg(resource.data.get('orgId', null));
      allow create: if creatingForUserOrg();
      allow update: if belongsToUserOrg();
      allow delete: if isOrgAdmin(existing().get('orgId', null));
    }

    match /assignments/{id} {
      allow read: if isSuperAdmin() || isSameOrg(resource.data.get('orgId', null));
      allow create: if creatingForUserOrg();
      allow update: if belongsToUserOrg();
      allow delete: if isOrgAdmin(existing().get('orgId', null));
    }

    function isValidCustomReport(data) {
      return data.keys().hasAll(['name', 'description', 'columns', 'createdAt', 'updatedAt', 'orgId']) &&
             data.name is string &&
             data.description is string &&
             data.columns is list &&
             data.orgId is string;
    }

    match /custom_reports/{id} {
      allow list: if isSignedIn();
      allow get: if isSuperAdmin() || belongsToUserOrg();
      allow create: if isOrgAdmin(incoming().get('orgId', null)) && (isSuperAdmin() || creatingForUserOrg()) && isValidCustomReport(incoming());
      allow update: if isOrgAdmin(existing().get('orgId', null)) && (isSuperAdmin() || belongsToUserOrg()) && isValidCustomReport(incoming());
      allow delete: if isOrgAdmin(existing().get('orgId', null)) && (isSuperAdmin() || belongsToUserOrg());
    }

    function isValidInventoryItem(data) {
      return data.keys().hasAll(['name', 'itemCode', 'category', 'locationId', 'quantity', 'orgId']) &&
             data.name is string && data.name.size() > 0 &&
             data.itemCode is string &&
             data.category is string &&
             (data.get('type', null) == null || data.type is string) &&
             data.locationId is string &&
             data.quantity is number &&
             isSameOrg(data.orgId);
    }

    match /inventory_items/{id} {
      allow read: if isSuperAdmin() || isSameOrg(resource.data.orgId);
      allow create: if isOrgAdmin(incoming().get('orgId', null)) && creatingForUserOrg() && isValidInventoryItem(incoming());
      allow update: if isSameOrg(existing().get('orgId', null)) && isValidInventoryItem(incoming()) && (
        isOrgAdmin(existing().get('orgId', null)) || 
        incoming().diff(existing()).affectedKeys().hasOnly(['quantity', 'updatedAt'])
      );
      allow delete: if isOrgAdmin(existing().get('orgId', null));
    }

    function isValidInventoryTransaction(data) {
      return data.keys().hasAll(['itemId', 'action', 'quantity', 'previousQuantity', 'newQuantity', 'userId', 'timestamp', 'orgId']) &&
             data.itemId is string && data.itemId.size() > 0 &&
             data.action is string && data.action in ['add', 'consume', 'audit', 'move'] &&
             data.quantity is number &&
             data.previousQuantity is number &&
             data.newQuantity is number &&
             data.userId is string &&
             isSameOrg(data.orgId);
    }

    match /inventory_transactions/{id} {
      allow read: if isSuperAdmin() || isSameOrg(resource.data.orgId);
      allow create: if creatingForUserOrg() && isValidInventoryTransaction(incoming());
      allow update, delete: if false; // Transactions should be immutable
    }

    match /invites/{token} {
      allow read: if true; // Tokens are secrets themselves
      allow create: if isOrgAdmin(incoming().get('orgId', null));
      allow update, delete: if isOrgAdmin(existing().get('orgId', null));
    }
  }
}
